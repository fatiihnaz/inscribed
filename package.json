{
  "name": "inscribed",
  "version": "3.1.0",
  "description": "Inline-editing CMS SDK for Next.js App Router projects",
  "keywords": [
    "cms",
    "headless-cms",
    "nextjs",
    "next",
    "react",
    "app-router",
    "inline-editing",
    "content-management",
    "tiptap",
    "sdk"
  ],
  "homepage": "https://github.com/fatiihnaz/inscribed#readme",
  "bugs": {
    "url": "https://github.com/fatiihnaz/inscribed/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fatiihnaz/inscribed.git"
  },
  "license": "LGPL-3.0-or-later",
  "author": "Fatih Naz <fatiihnaz@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cms-sync": "./dist/cli-sync.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./collections": {
      "types": "./dist/collections.d.ts",
      "import": "./dist/collections.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js"
    },
    "./page": {
      "types": "./dist/page.d.ts",
      "import": "./dist/page.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "COPYING"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "dependencies": {
    "@tiptap/extension-link": "^2.10.0",
    "@tiptap/pm": "^2.10.0",
    "@tiptap/react": "^2.10.0",
    "@tiptap/starter-kit": "^2.10.0",
    "framer-motion": "^11.11.0",
    "isomorphic-dompurify": "^2.18.0",
    "oxc-parser": "^0.134.0"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "next": "^15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.8"
  }
}
